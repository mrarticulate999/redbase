{
  "name": "redbase",
  "version": "1.0.0",
  "description": "REDBASE — internal operations dashboard for an AI red teaming consultancy.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node server/src/index.js",
    "start": "node server/src/index.js",
    "server:dev": "nodemon server/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "seed": "node prisma/seed.js",
    "setup": "prisma generate && prisma migrate deploy && node prisma/seed.js",
    "client:install": "npm --prefix client install",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "build": "npm run client:install && npm run client:build && prisma generate"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
