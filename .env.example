# ─────────────────────────────────────────────────────────────
# REDBASE environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
# When using docker-compose, host is `db`. For local Postgres use `localhost`.
DATABASE_URL="postgresql://redbase:redbase@localhost:5432/redbase?schema=public"

# Used by docker-compose to provision the Postgres container.
POSTGRES_USER=redbase
POSTGRES_PASSWORD=redbase
POSTGRES_DB=redbase

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Auth ---
# Generate a strong secret, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="8h"
BCRYPT_SALT_ROUNDS=12

# --- CORS ---
# Comma-separated list of allowed origins (the frontend URL).
CORS_ORIGIN="http://localhost:5173"

# --- Google Calendar OAuth2 ---
# Create an OAuth client in Google Cloud Console (see README) and paste here.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/calendar/oauth/callback"

# --- Frontend (Vite) ---
# These are read by the client at build time (must be prefixed with VITE_).
VITE_API_BASE_URL="http://localhost:4000/api"
