# ─────────────────────────────────────────────────────────────
# REDBASE environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
# When using docker-compose, host is `db`. For local Postgres use `localhost`.
DATABASE_URL="postgresql://redbase:redbase@localhost:5432/redbase?schema=public"

# Used by docker-compose to provision the Postgres container.
POSTGRES_USER=redbase
POSTGRES_PASSWORD=redbase
POSTGRES_DB=redbase

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Auth ---
# Generate a strong secret, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED and must be >= 32 chars — the server refuses to start otherwise.
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="8h"
BCRYPT_SALT_ROUNDS=12

# --- Account passwords (consumed by prisma/seed.js) ---
# Set a strong unique password per teammate. Changing one + re-seeding rotates it.
# If left blank, the seed generates a random password and prints it once.
# Var name = USERNAME_PASSWORD (grantj05 is admin; abehalim, rjlee are operators).
GRANTJ05_PASSWORD=""
ABEHALIM_PASSWORD=""
RJLEE_PASSWORD=""

# --- Encryption key for OAuth tokens at rest ---
# 32 bytes hex:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required if you use the Google Calendar module; tokens are stored encrypted.
TOKEN_ENCRYPTION_KEY=""

# --- CORS ---
# Comma-separated list of allowed origins (the frontend URL).
CORS_ORIGIN="http://localhost:5173"

# --- Google Calendar OAuth2 ---
# Create an OAuth client in Google Cloud Console (see README) and paste here.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/calendar/oauth/callback"

# --- CRM lead-acquisition engine ---
# Target number of ACTIVE qualifying leads the prospecting engine maintains.
CRM_LEAD_TARGET="100"
# Clay integration (optional). When CLAY_WEBHOOK_URL is set, the engine sends ICP
# prospecting requests to your Clay table; Clay posts enriched firms back to the
# clay-callback route. Without it, the engine uses the built-in generator source.
CLAY_WEBHOOK_URL=""
CLAY_API_KEY=""
CLAY_CALLBACK_URL="http://localhost:4000/api/crm/prospecting/clay-callback"
# Shared secret Clay must send as the x-clay-secret header on the callback.
CLAY_CALLBACK_SECRET=""

# --- Frontend (Vite) ---
# These are read by the client at build time (must be prefixed with VITE_).
VITE_API_BASE_URL="http://localhost:4000/api"
