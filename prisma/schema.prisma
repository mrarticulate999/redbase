// REDBASE — Prisma schema
// Postgres datasource, generated JS client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  operator
}

enum MessageTag {
  General
  Urgent
  Client
  Technical
}

enum TaskStatus {
  Backlog
  InProgress
  Review
  Done
}

enum Priority {
  High
  Medium
  Low
}

enum ClientStatus {
  Lead
  Active
  Completed
}

enum FinanceType {
  income
  expense
}

enum FinanceStatus {
  Paid
  Pending
  Overdue
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(operator)
  createdAt    DateTime @default(now())

  messages         Message[]
  assignedTasks    Task[]             @relation("TaskAssignee")
  learningProgress LearningProgress[]
  googleToken      GoogleToken?
}

model Message {
  id        String     @id @default(uuid())
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  tag       MessageTag @default(General)
  createdAt DateTime   @default(now())

  // Self-relation for threaded replies
  parent   Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  replies  Message[] @relation("MessageThread")

  @@index([parentId])
  @@index([createdAt])
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String     @default("")
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  status      TaskStatus @default(Backlog)
  priority    Priority   @default(Medium)
  dueDate     DateTime?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())

  @@index([status])
  @@index([assigneeId])
}

model Client {
  id           String       @id @default(uuid())
  name         String
  contactName  String       @default("")
  email        String       @default("")
  phone        String       @default("")
  industry     String       @default("")
  aiSystemType String       @default("")
  status       ClientStatus @default(Lead)
  notes        String       @default("")
  files        String[]     @default([])
  history      String[]     @default([])
  createdAt    DateTime     @default(now())

  tasks         Task[]
  financeEntries FinanceEntry[]

  @@index([status])
  @@index([industry])
}

model FinanceEntry {
  id            String         @id @default(uuid())
  type          FinanceType
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId      String?
  amount        Decimal        @db.Decimal(12, 2)
  category      String         @default("")
  description   String         @default("")
  invoiceNumber String?
  status        FinanceStatus?
  date          DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([type])
  @@index([date])
}

model LearningItem {
  id            String  @id @default(uuid())
  track         String
  title         String
  description   String  @default("")
  resourceUrl   String  @default("")
  estimatedHours Float  @default(1)
  order         Int     @default(0)

  progress LearningProgress[]

  @@index([track])
}

model LearningProgress {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  learningItem   LearningItem @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  learningItemId String
  completed      Boolean      @default(false)
  completedAt    DateTime?

  @@unique([userId, learningItemId])
}

model GoogleToken {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
