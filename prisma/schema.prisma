// REDBASE — Prisma schema
// Postgres datasource, generated JS client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Non-pooled connection used for migrations (Neon pooler can't run them).
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  operator
}

enum MessageTag {
  General
  Urgent
  Client
  Technical
}

enum TaskStatus {
  Backlog
  InProgress
  Review
  Done
}

enum Priority {
  High
  Medium
  Low
}

enum ClientStatus {
  Lead
  Active
  Completed
}

enum FinanceType {
  income
  expense
}

enum FinanceStatus {
  Paid
  Pending
  Overdue
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(operator)
  createdAt    DateTime @default(now())

  messages         Message[]
  assignedTasks    Task[]             @relation("TaskAssignee")
  learningProgress LearningProgress[]
  googleToken      GoogleToken?
  milestones       Milestone[]
  objectives       Objective[]
}

model Message {
  id        String     @id @default(uuid())
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  tag       MessageTag @default(General)
  createdAt DateTime   @default(now())

  // Self-relation for threaded replies
  parent   Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  replies  Message[] @relation("MessageThread")

  @@index([parentId])
  @@index([createdAt])
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String     @default("")
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  status      TaskStatus @default(Backlog)
  priority    Priority   @default(Medium)
  dueDate     DateTime?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())

  @@index([status])
  @@index([assigneeId])
}

model Client {
  id           String       @id @default(uuid())
  name         String
  contactName  String       @default("")
  email        String       @default("")
  phone        String       @default("")
  industry     String       @default("")
  aiSystemType String       @default("")
  status       ClientStatus @default(Lead)
  notes        String       @default("")
  files        String[]     @default([])
  history      String[]     @default([])
  createdAt    DateTime     @default(now())

  tasks         Task[]
  financeEntries FinanceEntry[]

  @@index([status])
  @@index([industry])
}

model FinanceEntry {
  id            String         @id @default(uuid())
  type          FinanceType
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId      String?
  amount        Decimal        @db.Decimal(12, 2)
  category      String         @default("")
  description   String         @default("")
  invoiceNumber String?
  status        FinanceStatus?
  date          DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([type])
  @@index([date])
}

model LearningItem {
  id            String  @id @default(uuid())
  track         String
  title         String
  description   String  @default("")
  resourceUrl   String  @default("")
  estimatedHours Float  @default(1)
  order         Int     @default(0)

  progress LearningProgress[]

  @@index([track])
}

model LearningProgress {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  learningItem   LearningItem @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  learningItemId String
  completed      Boolean      @default(false)
  completedAt    DateTime?

  @@unique([userId, learningItemId])
}

model GoogleToken {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Milestone {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  category    String
  timeframe   String
  description String   @default("")
  status      String   @default("planned")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime @default(now())

  @@index([timeframe])
  @@index([date])
}

model Objective {
  id         String      @id @default(uuid())
  title      String
  timeframe  String
  status     String      @default("active")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  keyResults KeyResult[]
  createdAt  DateTime    @default(now())

  @@index([timeframe])
}

model KeyResult {
  id          String    @id @default(uuid())
  title       String
  target      Float
  current     Float     @default(0)
  unit        String    @default("%")
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  objectiveId String
  createdAt   DateTime  @default(now())
}

// ============================================================================
// CRM / CloudGuard sales engine
// Embedded sales CRM for the land-and-expand motion (DMV law-firm beachhead,
// US-wide prospecting). `Company` = a prospect/lead firm; distinct from the
// `Client` model above, which represents signed/engaged customers.
// ============================================================================

enum Vertical {
  law
  accounting
  ria
  other
}

enum PersonaRole {
  economic_buyer
  champion
  it
  other
}

enum ServiceType {
  posture_assessment
  red_teaming
  remediation
  ai_enablement
}

enum ActivityKind {
  call
  email
  note
  meeting
  task
}

enum RelatedKind {
  company
  contact
  deal
  ticket
}

enum TicketStatus {
  open
  pending
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum LeadStatus {
  new
  working
  nurture
  converted
  disqualified
}

model Company {
  id                String      @id @default(uuid())
  name              String
  vertical          Vertical    @default(law)
  website           String?
  domain            String?     @unique          // dedup key for prospecting
  linkedinUrl       String?
  state             String?
  county            String?
  city              String?
  attorneyCount     Int?
  staffCount        Int?
  practiceAreas     String[]    @default([])
  independent       Boolean     @default(true)
  aiAdoptionSignals Json        @default("{}")
  triggerEvents     Json        @default("[]")
  priorityScore     Int         @default(0)
  geoTier           String      @default("us")   // dmv_core | dmv_state | adjacent | us
  disqualified      Boolean     @default(false)
  leadStatus        LeadStatus  @default(new)
  source            String      @default("manual") // clay | generated | referral | manual | import
  owner             String?
  createdAt         DateTime    @default(now())

  contacts Contact[]
  deals    Deal[]
  tickets  Ticket[]

  @@index([priorityScore])
  @@index([leadStatus])
  @@index([disqualified])
  @@index([state])
}

model Contact {
  id          String      @id @default(uuid())
  company     Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId   String?
  firstName   String
  lastName    String
  title       String?
  personaRole PersonaRole @default(other)
  email       String?
  phone       String?
  createdAt   DateTime    @default(now())

  @@index([companyId])
}

model Deal {
  id            String      @id @default(uuid())
  company       Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String?
  name          String
  serviceType   ServiceType @default(posture_assessment)
  stage         String      @default("new") // references PipelineStage.key
  amount        Decimal     @db.Decimal(12, 2) @default(0)
  probability   Int         @default(5)
  expectedClose DateTime?
  source        String?
  owner         String?
  createdAt     DateTime    @default(now())

  @@index([companyId])
  @@index([stage])
}

model Activity {
  id          String       @id @default(uuid())
  relatedType RelatedKind
  relatedId   String
  type        ActivityKind @default(note)
  body        String       @default("")
  dueAt       DateTime?
  completed   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([relatedType, relatedId])
  @@index([type])
}

model Ticket {
  id              String         @id @default(uuid())
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId       String?
  contactId       String?
  subject         String
  status          TicketStatus   @default(open)
  priority        TicketPriority @default(medium)
  assignee        String?
  resolutionNotes String?
  openedAt        DateTime       @default(now())
  resolvedAt      DateTime?

  @@index([companyId])
  @@index([status])
}

model PipelineStage {
  id          String @id @default(uuid())
  key         String @unique
  label       String
  probability Int    @default(0)
  position    Int    @default(0)
}

model Segment {
  id         String   @id @default(uuid())
  name       String
  filterJson Json     @default("{}")
  createdAt  DateTime @default(now())
}

model ScoringConfig {
  id        Int      @id @default(1)
  weights   Json
  updatedAt DateTime @default(now()) @updatedAt
}

model ProspectRun {
  id         String   @id @default(uuid())
  source     String   // clay | generated
  requested  Int      @default(0)
  discovered Int      @default(0)
  qualified  Int      @default(0)
  inserted   Int      @default(0)
  activeAfter Int     @default(0)
  note       String   @default("")
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
